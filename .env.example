# Copy to .env and adjust. Never commit your real .env (it is gitignored).

# --- Database ---
# MongoDB populated with your own credentialed MIMIC-IV (see docs/DATA_ACCESS.md)
MONGO_URI=mongodb://localhost:27017/

# --- Paths (override the in-repo defaults if your data/models live elsewhere) ---
# DATA_DIR=./datasets
# MODEL_DIR=./models

# --- Logging / API ---
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# --- Optional: hosted LLM for app_06 clinical chat ---
# Leave unset to use local Ollama models only (default).
# OPENAI_API_KEY=
