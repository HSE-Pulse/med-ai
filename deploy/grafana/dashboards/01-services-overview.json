{
  "uid": "medai-services",
  "title": "MedAI — Services Overview",
  "tags": ["medai", "otel", "services"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{job=\"medai-services\"}, service)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Services up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "count(up{job=\"medai-services\"} == 1)", "legendFormat": "up" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "green", "value": 17 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 2,
      "title": "Services down",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "count(up{job=\"medai-services\"} == 0) OR on() vector(0)", "legendFormat": "down" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "OTel spans received/s",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "rate(otelcol_receiver_accepted_spans_total[1m])", "legendFormat": "{{receiver}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "title": "OTel exporter queue size",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "otelcol_exporter_queue_size", "legendFormat": "{{exporter}}" }
      ]
    },
    {
      "id": 5,
      "title": "OTel spans dropped/s (should be 0)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "rate(otelcol_exporter_send_failed_spans_total[5m])", "legendFormat": "{{exporter}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Per-service up status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "expr": "up{job=\"medai-services\", service=~\"$service\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Python GC collections by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "description": "Visible when services export python_gc_objects_collected_total (prometheus_fastapi_instrumentator).",
      "targets": [
        { "expr": "rate(python_gc_objects_collected_total{service=~\"$service\"}[1m])", "legendFormat": "{{service}} gen{{generation}}" }
      ]
    },
    {
      "id": 20,
      "title": "Process resident memory by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "process_resident_memory_bytes{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 21,
      "title": "Process CPU seconds by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{service=~\"$service\"}[1m])", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    }
  ]
}
