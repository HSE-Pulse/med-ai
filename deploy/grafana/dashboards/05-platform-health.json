{
  "uid": "medai-platform-health",
  "title": "MedAI — Platform Health & SLOs",
  "tags": ["medai", "slo", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Platform availability",
      "description": "% of MedAI services currently responding to Prometheus scrapes. Target: 100% in prod.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "avg(up{job=\"medai-services\"}) * 100",
          "legendFormat": "availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Services up / expected",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 4, "h": 5 },
      "targets": [
        { "expr": "count(up{job=\"medai-services\"} == 1)", "legendFormat": "up" },
        { "expr": "count(up{job=\"medai-services\"})", "legendFormat": "expected" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 14 },
              { "color": "green", "value": 18 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Error rate (last 5m)",
      "description": "Log lines at ERROR or CRITICAL level per minute, aggregated across every service.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "sum(rate({source=\"medai\"} | json | level=~\"ERROR|CRITICAL\" [5m]))",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Traces received/s",
      "description": "Rate at which the OTel Collector is ingesting spans from the services.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 14, "y": 0, "w": 4, "h": 5 },
      "targets": [
        { "expr": "sum(rate(otelcol_receiver_accepted_spans_total[1m]))", "legendFormat": "spans/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "Kafka consumer lag (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        {
          "expr": "sum(max by (redpanda_topic, redpanda_partition) (redpanda_kafka_max_offset) - on(redpanda_topic, redpanda_partition) group_right max by (redpanda_group, redpanda_topic, redpanda_partition) (redpanda_kafka_consumer_group_committed_offset)) OR on() vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Availability over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "avg(up{job=\"medai-services\"}) * 100",
          "legendFormat": "availability %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 11,
      "title": "Error-rate by service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate({source=\"medai\"} | json | level=~\"ERROR|CRITICAL\" [1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 20,
      "title": "Memory footprint by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"medai-services\"}",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 21,
      "title": "CPU utilisation by service",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"medai-services\"}[1m])",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 30,
      "title": "Open file descriptors",
      "description": "Watch for leaks — sustained climb means a service is holding sockets / files it isn't releasing.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_open_fds{job=\"medai-services\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 31,
      "title": "Python GC collections / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate(python_gc_collections_total{job=\"medai-services\"}[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
