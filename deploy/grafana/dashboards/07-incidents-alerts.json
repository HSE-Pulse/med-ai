{
  "uid": "medai-incidents",
  "title": "MedAI — Incidents & Alerts",
  "tags": ["medai", "alerts", "oncall"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values({source=\"medai\"}, service)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CRITICAL (last 1h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 0, "w": 5, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\", service=~\"$service\"} | json | level=\"CRITICAL\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "ERROR (last 1h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 5, "y": 0, "w": 5, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\", service=~\"$service\"} | json | level=\"ERROR\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "WARNING (last 1h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 10, "y": 0, "w": 5, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\", service=~\"$service\"} | json | level=\"WARNING\" [1h]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Capacity alerts (last 1h)",
      "description": "/notify-capacity-alert calls logged by bed_management → hospital_ops.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 15, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\"} |~ \"notify-capacity-alert|capacity_alert\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Circuit-breaker trips (last 1h)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\"} |~ \"circuit_breaker.*open|breaker.*tripped\" [1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Error + Critical stream (newest first)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 12 },
      "targets": [
        {
          "expr": "{source=\"medai\", service=~\"$service\"} | json | level=~\"ERROR|CRITICAL\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 11,
      "title": "Error rate by service",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate({source=\"medai\", service=~\"$service\"} | json | level=~\"ERROR|CRITICAL\" [1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Capacity alert burst",
      "description": "Time-series of bed_management capacity alerts — spikes here often precede ED crowding",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate({source=\"medai\"} |~ \"capacity_alert|notify-capacity-alert\" [1m]))",
          "legendFormat": "capacity alerts"
        }
      ]
    },
    {
      "id": 13,
      "title": "Top-10 error patterns (last 30m)",
      "description": "Aggregates by logger + msg prefix so repeated errors collapse.",
      "type": "table",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (service, logger) (count_over_time({source=\"medai\"} | json | level=~\"ERROR|CRITICAL\" [30m])))"
        }
      ]
    }
  ]
}
