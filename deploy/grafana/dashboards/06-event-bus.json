{
  "uid": "medai-event-bus",
  "title": "MedAI — Event Bus & Outbox",
  "tags": ["medai", "kafka", "event-bus", "outbox"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "topic",
        "label": "Topic",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(redpanda_kafka_request_bytes_total, redpanda_topic)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total events in Mongo event_log (all time)",
      "description": "Durable tier count — every event produced since the sim started. Shows persistence layer health.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\"} |~ \"event_published\" [$__range]))",
          "legendFormat": "events published"
        }
      ]
    },
    {
      "id": 2,
      "title": "Published events/sec",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 6, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate({source=\"medai\"} |~ \"event_published\" [1m]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } }
    },
    {
      "id": 3,
      "title": "Outbox pending",
      "description": "Events queued but not yet acknowledged by the bus. Sustained >0 = broker/Mongo blip.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 10, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\"} |~ \"outbox_publish_failed\" [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Outbox relay retries (5m)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 14, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({source=\"medai\"} |~ \"outbox_relay: relayed\" [5m]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Broker active consumers",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "count(count by (redpanda_group) (redpanda_kafka_consumer_group_committed_offset))" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 14 },
              { "color": "green", "value": 17 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Event publication rate by topic",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate({source=\"medai\"} |~ \"event_published\" [1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Kafka message rate (produce vs fetch)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (redpanda_request) (rate(redpanda_kafka_request_bytes_total[1m]))",
          "legendFormat": "{{redpanda_request}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 12,
      "title": "Consumer lag top-5 (lagging groups/topics)",
      "description": "Positive lag = consumer is behind. A consumer stuck >1000 usually indicates the handler is crashing.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "topk(5, max by (redpanda_group, redpanda_topic) (redpanda_kafka_max_offset) - on(redpanda_topic, redpanda_partition) group_right max by (redpanda_group, redpanda_topic, redpanda_partition) (redpanda_kafka_consumer_group_committed_offset))",
          "legendFormat": "{{redpanda_group}} / {{redpanda_topic}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Recent event_published lines",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{source=\"medai\"} |~ \"event_published\" | json"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 14,
      "title": "Broker errors / failures",
      "description": "outbox_publish_failed, kafka_produce_failed, broker_produce_failed — every sign the broker layer lost something.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "{source=\"medai\"} |~ \"outbox_publish_failed|kafka_produce_failed|broker_produce_failed|kafka_consumer_start_failed\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
